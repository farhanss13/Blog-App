PORT=3000

# MongoDB Atlas (Drivers → Node.js). Example:
# DB_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/blogapp?retryWrites=true&w=majority
# If you see "querySrv ECONNREFUSED", code now prefers IPv4; also whitelist IPs in Atlas
# Network Access. Still failing? Use Atlas "standard connection string" (mongodb://..., not srv).
DB_URL=mongodb://127.0.0.1:27017/blogapp

JWT_SECRET=use_a_long_random_string_in_production

# Cloudinary (blog images / avatars)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional for local dev (leave unset = allow any origin). In production set your deployed frontend URL(s),
# comma-separated, no trailing slash (e.g. https://myapp.vercel.app).
# FRONTEND_URL=https://myapp.vercel.app
